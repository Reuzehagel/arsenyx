# Force LF line endings across the repo so oxfmt/oxlint behave the same on
# Windows, macOS, and Linux regardless of core.autocrlf settings.
* text=auto eol=lf

# Lockfiles should never be touched by humans; keep LF and mark as generated.
bun.lock binary
*.lock binary

# Generated Prisma client output is regenerated by `prisma generate`.
apps/api/src/generated/** linguist-generated=true

# Static binary content
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
