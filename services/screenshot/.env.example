# Bind
PORT=3000

# Database — Neon connection string, scoped role with SELECT on "ApiKey" only
DATABASE_URL=postgres://readonly:pw@ep-xxx.neon.tech/arsenyx?sslmode=require

# R2 (S3-compatible)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=arsenyx-screenshots

# Cloudflare API — for cache purge after invalidation
CF_ZONE_ID=
CF_API_TOKEN=

# Shared secret with apps/api for the /invalidate endpoint
SHARED_SECRET=

# Origins allowed to request screenshots without a PAT (comma-separated)
ALLOWED_SCREENSHOT_ORIGINS=https://arsenyx.com,https://www.arsenyx.com,https://profit-taker.com,https://testing.profit-taker.com

# Base URL Playwright navigates to for /builds/<slug>
SCREENSHOT_BASE_URL=https://arsenyx.com

# Public URL of this service (used for CF cache purge URLs)
PUBLIC_BASE_URL=https://ss.arsenyx.com
